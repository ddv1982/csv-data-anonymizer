{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Default desktop capability for CSV Anonymizer commands and file dialogs",
  "windows": ["main"],
  "permissions": [
    "allow-load-settings",
    "allow-save-settings",
    "allow-pick-input-csv",
    "allow-pick-output-csv",
    "allow-analyze-csv",
    "allow-analyze-pasted-data",
    "allow-count-csv-rows",
    "allow-preflight-anonymization",
    "allow-preview-anonymization",
    "allow-preview-pasted-data",
    "allow-anonymize-pasted-data",
    "allow-generate-quick-values",
    "allow-start-anonymize-job",
    "allow-get-anonymize-job-status",
    "allow-cancel-anonymize-job",
    "allow-get-local-ai-status",
    "allow-start-local-ai-model-download",
    "allow-get-local-ai-model-download-status",
    "allow-cancel-local-ai-model-download",
    "allow-open-local-ai-setup-url",
    "allow-open-output-location",
    "core:default",
    "core:app:allow-set-app-theme"
  ]
}
