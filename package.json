{
  "name": "csv-anonymizer",
  "version": "1.0.7",
  "description": "Desktop CSV anonymizer for local-first anonymization workflows.",
  "desktopName": "csv-anonymizer.desktop",
  "homepage": "https://github.com/ddv1982/csv-data-anonymizer",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run renderer:build && electrobun dev",
    "dev:watch": "bun run renderer:build && electrobun dev --watch",
    "build": "bun run typecheck && bun run renderer:build && bun scripts/run-electrobun-build.mjs --env=dev",
    "build:canary": "bun run typecheck && bun run renderer:build && bun scripts/run-electrobun-build.mjs --env=canary",
    "build:stable": "bun run typecheck && bun run renderer:build && bun scripts/run-electrobun-build.mjs --env=stable",
    "preview": "electrobun run",
    "renderer:dev": "vite --config vite.renderer.config.ts",
    "renderer:build": "vite build --config vite.renderer.config.ts",
    "dist": "bun run build:stable",
    "dist:electrobun": "bun run build:stable",
    "dist:dir": "bun run build:stable",
    "dist:mac": "bun run build:stable",
    "dist:mac:dir": "bun run build:stable",
    "dist:linux": "bun run build:stable && bun run linux:packages",
    "dist:linux:dir": "bun run build:stable",
    "icons:linux": "bun scripts/generate-linux-icons.mjs",
    "linux:packages": "bun scripts/package-electrobun-linux.mjs",
    "linux:metadata:check": "python3 scripts/validate_linux_package_metadata.py \"dist/electrobun/artifacts/*.deb\" \"dist/electrobun/artifacts/*.rpm\"",
    "linux:package-manager:check": "bun run linux:packages && bun run linux:metadata:check && bun run apt:repo:check",
    "apt:repo:check": "bun scripts/check-apt-repository.mjs",
    "release:check": "bun scripts/check-release-metadata.mjs",
    "artifacts:electrobun:check": "bun scripts/check-electrobun-artifacts.mjs",
    "smoke:packaged": "bun run smoke:electrobun",
    "smoke:electrobun": "bun scripts/electrobun-smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bun run smoke:electrobun",
    "lint": "tsc -b --noEmit",
    "typecheck": "tsc -b --noEmit"
  },
  "keywords": [
    "csv",
    "anonymizer",
    "privacy",
    "data",
    "desktop"
  ],
  "author": "Douwe de Vries <douwe.de.vries.82@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "overrides": {
    "@faker-js/faker": "10.4.0",
    "esbuild": "0.28.1",
    "happy-dom": "20.10.4"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@lucide/vue": "^1.20.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "papaparse": "^5.5.3",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "electrobun": "1.18.1",
    "happy-dom": "^20.10.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
