{
  "name": "csv-anonymizer",
  "version": "1.0.0",
  "description": "Desktop CSV anonymizer for local-first anonymization workflows.",
  "main": "out/main/index.js",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm run build && electron-builder",
    "dist:dir": "pnpm run build && electron-builder --dir",
    "smoke:packaged": "node scripts/packaged-smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm run build && playwright test",
    "lint": "tsc -b --noEmit",
    "typecheck": "tsc -b --noEmit"
  },
  "keywords": [
    "csv",
    "anonymizer",
    "privacy",
    "data",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@faker-js/faker": "^10.4.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "@lucide/vue": "^1.0.0",
    "papaparse": "^5.5.3",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.4.0",
    "vue": "^3.5.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.23",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "build": {
    "appId": "com.csv-anonymizer.app",
    "productName": "CSV Anonymizer",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "npmRebuild": false,
    "publish": null,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
