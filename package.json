{
  "name": "csv-anonymizer",
  "version": "1.0.76",
  "description": "Desktop CSV anonymizer for local-first data transformation workflows.",
  "desktopName": "csv-anonymizer.desktop",
  "homepage": "https://github.com/ddv1982/csv-data-anonymizer",
  "scripts": {
    "dev": "cd src-tauri && cargo tauri dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:test": "npm --prefix frontend run test",
    "frontend:e2e": "npm --prefix frontend run e2e",
    "frontend:a11y": "npm --prefix frontend run a11y",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "frontend:audit": "npm audit --prefix frontend --audit-level=high",
    "frontend:deadcode": "npm --prefix frontend run deadcode",
    "frontend:deadcode:production": "npm --prefix frontend run deadcode:production",
    "contracts:check": "node scripts/check-contracts.mjs",
    "docs:test": "node --test scripts/__tests__/check-docs.test.mjs",
    "docs:check": "npm run docs:test && node scripts/check-docs.mjs",
    "stdnum:vat:check": "python3 scripts/verify_stdnum_vat_fixtures.py",
    "tauri:dev": "cd src-tauri && cargo tauri dev",
    "tauri:prebuilt:check": "npm run frontend:build && bash scripts/check-tauri-prebuilt-frontend.sh",
    "tauri:build": "cd src-tauri && cargo tauri build",
    "build": "npm run frontend:build && cargo build --workspace",
    "build:stable": "npm run tauri:build",
    "dist": "npm run tauri:build",
    "dist:mac": "cd src-tauri && cargo tauri build --bundles dmg",
    "dist:mac:app": "cd src-tauri && cargo tauri build --bundles app",
    "dist:linux": "node scripts/package-tauri-linux.mjs",
    "linux:metadata:check": "python3 scripts/validate_linux_package_metadata.py \"dist/rust/artifacts/*.deb\" \"dist/rust/artifacts/*.rpm\"",
    "linux:metadata:test": "python3 -m unittest tests.test_linux_package_metadata",
    "linux:release-helpers:check": "bash scripts/check-linux-release-helpers.sh",
    "linux:package-manager:check": "node scripts/package-tauri-linux.mjs && npm run linux:metadata:check -- --skip-external-tools && npm run apt:repo:check && npm run apt:installer:check",
    "apt:repo:check": "node scripts/check-apt-repository.mjs",
    "apt:installer:check": "node scripts/check-apt-installer.mjs",
    "release:check": "node scripts/check-release-metadata.mjs && npm run linux:metadata:test",
    "artifacts:rust:check": "node scripts/check-rust-artifacts.mjs",
    "cargo:audit": "node scripts/cargo-audit.mjs",
    "cargo:audit:required": "node scripts/cargo-audit.mjs --required",
    "cargo:audit:test": "node --test scripts/__tests__/cargo-audit.test.mjs",
    "workflows:test": "node --test scripts/__tests__/workflow-hardening.test.mjs",
    "tooling:test": "npm run cargo:audit:test && npm run workflows:test && npm run linux:metadata:test",
    "cargo:machete": "node scripts/cargo-machete.mjs",
    "cargo:machete:required": "node scripts/cargo-machete.mjs --required",
    "deadcode:strict": "npm --prefix frontend exec knip -- --config knip.json --production --include exports,types,dependencies,unlisted,unresolved,binaries",
    "deadcode:required": "npm run frontend:deadcode && npm run frontend:deadcode:production && npm run deadcode:strict && npm run cargo:machete:required",
    "smoke:rust": "node scripts/rust-smoke.mjs",
    "fmt": "cargo fmt --all --check",
    "lint": "npm run frontend:lint && node scripts/ensure-frontend-dist.mjs && cargo clippy --workspace --all-targets -- -D warnings",
    "test": "npm run contracts:check && npm run frontend:test && node scripts/ensure-frontend-dist.mjs && cargo test --workspace",
    "typecheck": "npm run frontend:typecheck && node scripts/ensure-frontend-dist.mjs && cargo check --workspace"
  },
  "keywords": [
    "csv",
    "anonymizer",
    "privacy",
    "data",
    "desktop"
  ],
  "author": "Douwe de Vries <douwe.de.vries.82@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  }
}
